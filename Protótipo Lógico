# Protótipo Lógico: Escâner de Matéria - Módulo de Identificação
def escanear_propriedades(material):
    # Aqui simulamos a 'espiral' de análise do material
    base_dados = {
        "ferro": {"densidade": 7.8, "condutividade": "Alta", "origem": "Terrestre"},
        "quartzo": {"densidade": 2.6, "condutividade": "Baixa", "origem": "Mineral"},
        "desconhecido": {"densidade": 0.0, "condutividade": "Infinita", "origem": "Arcturiana"}
    }
    
    resultado = base_dados.get(material.lower(), "Material não identificado no banco de dados local.")
    return resultado

# Teste do fluxo
objeto = input("Aproxime o material para análise: ")
print(f"Analisando frequências de {objeto}...")
print(escanear_propriedades(objeto))

import random

def simular_leitura_sensor(valor_real):
    # Simula a oscilacao do hardware (ruido de 1%)
    variacao = valor_real * 0.01
    return round(valor_real + random.uniform(-variacao, variacao), 2)

# No seu loop de teste:
print(f"Lendo frequencias de {objeto}...")
leitura_densidade = simular_leitura_sensor(base_dados[objeto]['densidade'])
print(f"Hardware reporta Densidade: {leitura_densidade} g/cm3")

# Protocolo de Segurança ATM - Filtro de Contaminantes
def verificar_seguranca_ambiental(material_detectado):
    # Lista de materiais que ativam o protocolo de risco
    contaminantes_perigosos = {
        "mercurio": "ALERTA: Metal pesado detectado. Risco de contaminação do lençol freático.",
        "chumbo": "ALERTA: Alta toxicidade detectada. Solo impróprio para manuseio direto.",
        "arsenio": "PERIGO CRÍTICO: Substância altamente letal identificada."
    }

    material_limpo = material_detectado.lower()

    if material_limpo in contaminantes_perigosos:
        print("\n" + "!" * 50)
        print(contaminantes_perigosos[material_limpo])
        print("SISTEMA TRAVADO: Operação interrompida para preservação ambiental.")
        print("!" * 50 + "\n")
        return False  # Bloqueia a operação
    else:
        print(f"\n[OK] Material '{material_detectado}' seguro para análise profunda.")
        return True   # Autoriza a operação

# --- Integração no Fluxo Principal ---
objeto = input("Aproxime o material para análise: ")

if verificar_seguranca_ambiental(objeto):
    # Se for seguro, o sistema procede com a análise de densidade/condutividade
    print(f"Analisando frequências de {objeto}...")
